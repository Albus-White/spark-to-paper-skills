{
  "name": "neurips_official",
  "display_name": "NeurIPS 2025 (single-column, author-year) — OFFICIAL style files",
  "official": true,
  "provenance": "Official NeurIPS 2025 LaTeX style file neurips_2025.sty fetched verbatim from media.neurips.cc/Conferences/NeurIPS2025/Styles.zip (dated 2025-05-12). Compiled with the 'preprint' option (non-anonymous, no line numbers) for a technical-report release. NeurIPS 2026 style files were not yet published at fetch time.",
  "engine": {
    "documentclass": "{article}",
    "style_package": "neurips_2025",
    "is_class": false,
    "assets": ["neurips_2025.sty"],
    "main_template": "main.tex.tmpl"
  },
  "sections": [
    {"id": "introduction", "title": "Introduction", "words": [650, 1000],
     "recipe": {"contrib_items": 4, "min_cites": 8}},
    {"id": "related_work", "title": "Related Work", "words": [600, 1000],
     "recipe": {"theme_subsections": 4, "closing_paragraph": true, "cites_per_theme": [4, 8]}},
    {"id": "approach", "title": "System Design", "words": [1000, 1700],
     "recipe": {"require_notation_table": false, "min_pseudocode": 1, "design_rationale": true}},
    {"id": "pipeline", "title": "The Generation Pipeline", "words": [1100, 1800],
     "recipe": {"min_pseudocode": 1, "design_rationale": true}},
    {"id": "integrity", "title": "Integrity and the Quality Stack", "words": [750, 1300],
     "recipe": {"design_rationale": true}},
    {"id": "figure_engine", "title": "The Editable-Vector Figure Engine", "words": [650, 1100],
     "recipe": {"design_rationale": true}},
    {"id": "evaluation", "title": "Evaluation Protocol", "words": [650, 1100],
     "recipe": {"result_tables": ["main_results", "ablation_results"], "display_math": false}},
    {"id": "discussion", "title": "Discussion, Limitations, and Broader Impact", "words": [600, 1050],
     "recipe": {"require_failure_mode": true}},
    {"id": "conclusion", "title": "Conclusion", "words": [150, 280],
     "recipe": {"paragraphs": 1, "lists": false}}
  ],
  "writing_order": ["approach", "pipeline", "integrity", "figure_engine", "related_work", "introduction", "evaluation", "discussion", "conclusion", "abstract"],
  "abstract": {"words": [150, 250], "paragraphs": 1, "cites": false, "math": false, "single_paragraph": true},
  "contributions": {"count": 4},
  "title": {"max_words": 18, "max_chars": 160},
  "keywords": {"min": 0, "max": 0, "cap": 0, "lowercase": false},
  "citations": {
    "style": "author_year",
    "natbib_options": "round",
    "bibstyle": "plainnat",
    "floor": 42,
    "types": ["CORE", "CONTEXT", "BASELINE", "METRIC", "DEFINITION"],
    "per_section_coverage": {"related_work": [18, 28], "introduction": [8, 12]},
    "in_abstract": false,
    "in_headings": false,
    "merge_adjacent": false
  },
  "tables": {"caption_position": "above", "min": 2},
  "experiment_complexity": "moderate",
  "figures": {"caption_position": "below", "min": 7, "distribute_across": ["approach", "pipeline", "integrity", "figure_engine", "evaluation"]},
  "headings": {"case": "title", "numbered": true},
  "masthead": {"journal": "", "homepage": "", "band_rgb": null, "copyright": "",
               "doi_prefix": "", "default_vol": "", "default_issue": "", "default_month": "", "default_year": ""},
  "results_mode": "proposal"
}
