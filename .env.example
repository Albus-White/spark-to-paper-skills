# spark-to-paper-skills — UNIFIED secrets/config.
# Copy to ./.env (gitignored, never commit). Auto-loaded by the skill scripts (_dotenv.py).
# A real exported env var always overrides a value here.

# --- GPT vision/text (ts-figure-optimize hybrid text-correction + vision diff) ---
# Optional: if unset, these fall back to ~/.codex/auth.json.
OPENAI_API_KEY=
VISION_MODEL=gpt-5.5
VISION_BASE_URL=

# --- Embeddings (ts-kg-build, ts-idea2story) ---
TS_EMBED_API_KEY=
TS_EMBED_BASE_URL=https://api.openai.com/v1
TS_EMBED_MODEL=

# --- Image generation (ts-paper-figure) ---
TS_FIG_API_KEY=
TS_FIG_BASE_URL=
TS_FIG_MODEL=

# NOTE: DrawAI/Codex (legacy pure-A vector redraw) authenticates via ~/.codex/auth.json, not this file.

# --- Overleaf (ONLY for Stage 8 sci-paper-repair, and only if you enable it) ---
# Off by default (paper_config.yaml: require_overleaf_url=false). To sync the repaired paper to Overleaf,
# set require_overleaf_url=true + push_* flags in the workspace paper_config.yaml, then fill these:
OVERLEAF_GIT_URL=
OVERLEAF_TOKEN=
